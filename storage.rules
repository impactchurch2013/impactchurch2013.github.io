rules_version = '2';

// Paste into Firebase Console → Storage → Rules, or deploy:
// firebase deploy --only storage

service firebase.storage {
  match /b/{bucket}/o {

    // Onboarding pending uploads + profile photos (see index.html)
    match /profilePhotos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Existing member photo uploads from directory profile
    match /member-photos/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }
  }
}
