{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Local preview (live reload)",
      "type": "npm",
      "script": "preview",
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "label": "Local preview (python server)",
      "type": "shell",
      "command": "python -m http.server 5501",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      }
    }
  ]
}
