rules_version = '2';

// Paste into Firebase Console → Firestore → Rules (merge with your existing rules if needed).
// Deploy via CLI: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // Allowlist: document id = email, OR fields email / Email (see isUserAllowed in index.html)
    match /allowedUsers/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /members/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /pendingChanges/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
