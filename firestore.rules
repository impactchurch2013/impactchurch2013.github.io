rules_version = '2';

// Paste into Firebase Console → Firestore → Rules (merge with your existing rules if needed).
// Deploy via CLI: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // Must match SUPER_ADMINS + CHURCH_ADMINS in index.html (admin emails, lowercase).
    function isChurchAdminEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email.lower() in [
          "impactchurch2013@gmail.com",
          "admin1@church.com",
          "admin2@church.com"
        ];
    }

    // Allowlist: document id = email (see isUserAllowed in index.html)
    match /allowedUsers/{docId} {
      allow read: if request.auth != null;
      allow create, update: if false;
      allow delete: if isChurchAdminEmail();
    }

    match /members/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    match /pendingChanges/{docId} {
      allow read, write: if request.auth != null;
    }
  }
}
