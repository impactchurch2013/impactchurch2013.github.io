rules_version = '2';

// Paste into Firebase Console → Firestore → Rules (merge with your existing rules if needed).
// Deploy via CLI: firebase deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    function normalizedAuthEmail() {
      return request.auth.token.email.lower();
    }

    // Must match SUPER_ADMINS in auth-role-config.js (bootstrap admins, lowercase).
    function isSuperAdminEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && normalizedAuthEmail() in [
          "impactchurch2013@gmail.com"
        ];
    }

    function isChurchAdminEmail() {
      return request.auth != null
        && request.auth.token.email != null
        && (
          isSuperAdminEmail()
          || exists(/databases/$(database)/documents/admins/$(normalizedAuthEmail()))
        );
    }

    // Allowlist: document id = lowercase email (see isUserAllowed in index.html)
    match /allowedUsers/{docId} {
      allow read: if request.auth != null;
      allow create, update: if isChurchAdminEmail();
      allow delete: if isChurchAdminEmail();
    }

    match /members/{docId} {
      allow read: if request.auth != null;
      allow write: if isChurchAdminEmail();
    }

    match /admins/{docId} {
      allow read: if request.auth != null;
      allow create, update, delete: if isChurchAdminEmail();
    }

    match /pendingChanges/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update, delete: if isChurchAdminEmail();
    }

    match /adminLogs/{docId} {
      allow read: if isChurchAdminEmail();
      allow create: if isChurchAdminEmail();
    }
  }
}
